import requests
import json

def main():
    # As 5 fontes fornecidas
    urls = [
        "https://hydralinks.cloud/sources/fitgirl.json",
        "https://hydralinks.cloud/sources/onlinefix.json",
        "https://wkeynhk.online/steamgg.json",
        "https://davidkazumisource.com/fontekazumi.json",
        "https://raw.githubusercontent.com/KekitU/rutracker-hydra-links/main/all_categories.json"
    ]

    # Estrutura com o nome oficial da sua fonte
    fonte_final = {
        "name": "Star Sky Bypasser",
        "downloads": []
    }

    uris_adicionadas = set()
    total_analisado = 0

    print("=== Iniciando a Unificação: Star Sky Bypasser ===")
    
    for i, url in enumerate(urls, 1):
        print(f"[{i}/5] Buscando: {url} ...")
        try:
            response = requests.get(url, timeout=20)
            if response.status_code == 200:
                dados = response.json()
                downloads = dados.get("downloads", [])
                total_analisado += len(downloads)
                
                contagem_antes = len(fonte_final["downloads"])
                
                for jogo in downloads:
                    uris = jogo.get("uris", [])
                    if uris:
                        # Transforma a lista de uris em uma tupla para poder comparar no set
                        chave_unica = tuple(uris) if isinstance(uris, list) else uris
                        if chave_unica not in uris_adicionadas:
                            uris_adicionadas.add(chave_unica)
                            fonte_final["downloads"].append(jogo)
                
                adicionados = len(fonte_final["downloads"]) - contagem_antes
                print(f"    -> Sucesso! +{adicionados} jogos adicionados.")
            else:
                print(f"    -> Erro: Código de resposta {response.status_code}")
        except Exception as e:
            print(f"    -> Falha ao processar link: {e}")

    print("\n=== Gravando Arquivo Final ===")
    nome_arquivo = "star_sky_bypasser.json"
    
    try:
        with open(nome_arquivo, "w", encoding="utf-8") as f:
            json.dump(fonte_final, f, ensure_ascii=False, indent=2)
            
        print(f"Pronto! O arquivo '{nome_arquivo}' foi criado com sucesso.")
        print(f"Total de jogos processados: {total_analisado}")
        print(f"Total de jogos sem duplicatas: {len(fonte_final['downloads'])}")
        
    except IOError as e:
        print(f"Erro ao salvar o arquivo: {e}")

if __name__ == "__main__":
    main()
